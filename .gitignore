node_modules/
dist/
coverage/
*.tsbuildinfo
.DS_Store
*.log
.vite/
.turbo/
.idea/
.vscode/
.claude/*
!.claude/skills/

# `.pizza-doc/` is ignored ONLY in THIS framework repo.
# This monorepo uses the multi-space layout `spaces/<id>/` for its own
# demo / regression specs, so a stray `.pizza-doc/` here would just be
# a scratch space generated by `pd init` in the wrong cwd.
#
# Consumer projects should DO THE OPPOSITE — commit `.pizza-doc/` as a
# first-class source artifact alongside code. The INSTALL.md guide
# spells this out for downstream users.
.pizza-doc/

.pnpm-store/
.env
.env.*
!.env.example

# user spaces — only the canonical demo is shared
spaces/*/
!spaces/pizza-shop-demo/

# generated per-space JSON schemas — derived from packages/core Zod source.
# Fresh clones regenerate via `pd schemas regen` or `pd init`. Keeping them
# out of git avoids 11-file diff noise on every schema bump and prevents
# silent desync between committed schemas and Zod.
spaces/*/schemas/

# pnpm publish --report-summary output
pnpm-publish-summary.json

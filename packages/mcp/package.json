{
  "name": "@pizza-doc/mcp",
  "version": "0.6.0",
  "description": "MCP server exposing Pizza Doc as structured tools for AI agents.",
  "license": "MIT",
  "homepage": "https://github.com/PizzzaDog/pizza_doc",
  "repository": {
    "type": "git",
    "url": "https://github.com/PizzzaDog/pizza_doc.git",
    "directory": "packages/mcp"
  },
  "keywords": ["pizza-doc", "mcp", "model-context-protocol", "architecture", "yaml"],
  "type": "module",
  "bin": {
    "pd-mcp": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.0.4",
    "@pizza-doc/core": "workspace:*",
    "yaml": "2.6.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "typescript": "5.6.3"
  }
}
